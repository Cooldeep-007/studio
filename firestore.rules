
/**
 * Core Philosophy:
 * This ruleset enforces a strict multi-tenant security model centered around "Firms".
 * A user's access is determined by their membership and role within that firm.
 * The primary goal is to ensure no user from one firm can ever access data
 * from another firm, and that actions are restricted based on user roles.
 *
 * Data Structure & Roles:
 * - /users/{userId}: Private user profiles, storing their `firmId` and `role`.
 * - /firms/{firmId}: Root of a tenant's data.
 * - Roles: Owner, Admin, Accountant, Staff.
 *
 * Key Security Decisions:
 * - Strict Tenant Isolation: Access to `/firms/{firmId}` data requires matching `firmId`.
 * - Role-Based Access Control (RBAC): Write permissions (create, update, delete)
 *   are restricted based on the user's role (e.g., only Owners/Admins can manage companies).
 * - User Privacy: Users can only read/write their own profile.
 * - Write Integrity: All writes validate that the denormalized `firmId` and
 *   `companyId` within a document match the document's path.
 * - Immutable Audit Logs: Append-only for firm members.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =================================
    // Helper Functions
    // =================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function docExists() {
      return resource != null;
    }
    
    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return userProfile().role;
    }

    function isMemberOfFirm(firmId) {
      return isSignedIn() && userProfile().firmId == firmId;
    }
    
    function isExistingFirmMember(firmId) {
      return isMemberOfFirm(firmId) && docExists();
    }

    // Role-based helpers
    function isOwnerOrAdmin(firmId) {
      return isMemberOfFirm(firmId) && (userRole() == 'Owner' || userRole() == 'Admin');
    }
    
    function isAccountantOrHigher(firmId) {
      return isOwnerOrAdmin(firmId) || (isMemberOfFirm(firmId) && userRole() == 'Accountant');
    }

    function isStaffOrHigher(firmId) {
        return isAccountantOrHigher(firmId) || (isMemberOfFirm(firmId) && userRole() == 'Staff');
    }

    // =================================
    // Collection Rules
    // =================================

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.uid == userId;
      allow update: if isOwner(userId) && docExists() && request.resource.data.uid == resource.data.uid;
      allow delete: if false; // Users should not be able to delete their own profiles.
    }

    match /firms/{firmId} {
      allow get: if isMemberOfFirm(firmId);
      allow list: if false; // Disallow listing all firms.
      allow create: if request.resource.data.ownerId == request.auth.uid; // Only the user creating it can be the owner.
      allow update: if isOwnerOrAdmin(firmId) && request.resource.data.ownerId == resource.data.ownerId; // Prevent changing owner.
      allow delete: if isOwnerOrAdmin(firmId) && userRole() == 'Owner'; // Only owner can delete firm.
    }

    match /firms/{firmId}/auditLogs/{auditLogId} {
      allow get, list: if isOwnerOrAdmin(firmId);
      allow create: if isMemberOfFirm(firmId) && request.resource.data.firmId == firmId;
      allow update, delete: if false; // Immutable
    }
    
    match /firms/{firmId}/companies/{companyId} {
      allow get, list: if isMemberOfFirm(firmId);
      allow create: if isOwnerOrAdmin(firmId) && request.resource.data.firmId == firmId;
      allow update: if isOwnerOrAdmin(firmId) && request.resource.data.firmId == firmId;
      allow delete: if isOwnerOrAdmin(firmId);
    }

    match /firms/{firmId}/companies/{companyId}/ledgers/{ledgerId} {
      allow get, list: if isMemberOfFirm(firmId);
      allow create, update: if isAccountantOrHigher(firmId) && request.resource.data.firmId == firmId && request.resource.data.companyId == companyId;
      allow delete: if isOwnerOrAdmin(firmId);
    }

    match /firms/{firmId}/companies/{companyId}/vouchers/{voucherId} {
      allow get, list: if isMemberOfFirm(firmId);
      allow create: if isStaffOrHigher(firmId) && request.resource.data.firmId == firmId && request.resource.data.companyId == companyId && request.resource.data.createdByUserId == request.auth.uid;
      allow update: if isAccountantOrHigher(firmId) && request.resource.data.firmId == firmId && request.resource.data.companyId == companyId;
      allow delete: if isOwnerOrAdmin(firmId);
    }

    match /firms/{firmId}/companies/{companyId}/vouchers/{voucherId}/lineItems/{lineItemId} {
      allow get, list: if isMemberOfFirm(firmId);
      allow create: if isStaffOrHigher(firmId) && request.resource.data.firmId == firmId && request.resource.data.companyId == companyId;
      allow update: if isAccountantOrHigher(firmId) && request.resource.data.firmId == firmId && request.resource.data.companyId == companyId;
      allow delete: if isOwnerOrAdmin(firmId);
    }

    match /firms/{firmId}/companies/{companyId}/invoices/{invoiceId} {
      allow get, list: if isMemberOfFirm(firmId);
      allow create, update: if isAccountantOrHigher(firmId) && request.resource.data.firmId == firmId && request.resource.data.companyId == companyId;
      allow delete: if isOwnerOrAdmin(firmId);
    }
    
    match /firms/{firmId}/companies/{companyId}/invoiceTemplates/{templateId} {
      allow get, list: if isMemberOfFirm(firmId);
      allow create, update: if isOwnerOrAdmin(firmId) && request.resource.data.firmId == firmId && request.resource.data.companyId == companyId;
      allow delete: if isOwnerOrAdmin(firmId);
    }

    match /firms/{firmId}/companies/{companyId}/customFieldDefinitions/{definitionId} {
      allow get, list: if isMemberOfFirm(firmId);
      allow create, update, delete: if isOwnerOrAdmin(firmId) && request.resource.data.firmId == firmId && request.resource.data.companyId == companyId;
    }

    // Bank data is sensitive, read-only for most.
    match /firms/{firmId}/companies/{companyId}/bankTransactions/{bankTransactionId} {
      allow get, list: if isAccountantOrHigher(firmId);
      allow create, update: if isOwnerOrAdmin(firmId) && request.resource.data.firmId == firmId && request.resource.data.companyId == companyId;
      allow delete: if isOwnerOrAdmin(firmId);
    }

    match /firms/{firmId}/companies/{companyId}/uploadedBankStatements/{statementId} {
      allow get, list: if isAccountantOrHigher(firmId);
      allow create: if isAccountantOrHigher(firmId) && request.resource.data.firmId == firmId && request.resource.data.companyId == companyId && request.resource.data.uploadedByUserId == request.auth.uid;
      allow update, delete: if isOwnerOrAdmin(firmId);
    }

    match /firms/{firmId}/companies/{companyId}/tallyImportJobs/{jobId} {
      allow get, list: if isAccountantOrHigher(firmId);
      allow create: if isAccountantOrHigher(firmId) && request.resource.data.firmId == firmId && request.resource.data.companyId == companyId && request.resource.data.uploadedByUserId == request.auth.uid;
      allow update, delete: if isOwnerOrAdmin(firmId);
    }
  }
}

  